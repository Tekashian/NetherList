# Database Configuration
DATABASE_URL="postgresql://netherlist:netherlist_dev_password@localhost:5432/netherlist_db"

# Redis Configuration
REDIS_URL="redis://localhost:6379"

# JWT Secret (CHANGE IN PRODUCTION!)
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"

# Google OAuth 2.0 Configuration
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
GOOGLE_CALLBACK_URL="http://localhost:4000/auth/google/callback"

# Session Secret (for OAuth state)
SESSION_SECRET="your-session-secret-change-in-production"

# Server Configuration
NODE_ENV="development"
PORT=4000

# CORS Configuration
CORS_ORIGIN="http://localhost:3000"

# Optional: Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Optional: File Upload (for avatars)
MAX_FILE_SIZE=5242880
UPLOAD_DIR="./uploads"

# Optional: Email Configuration (for notifications)
# SMTP_HOST="smtp.gmail.com"
# SMTP_PORT=587
# SMTP_USER="your-email@gmail.com"
# SMTP_PASS="your-app-password"
# EMAIL_FROM="noreply@netherlist.com"

# Optional: Logging
LOG_LEVEL="debug"

# Optional: API Keys (for future integrations)
# BATTLE_NET_API_KEY="your-battle-net-api-key"
